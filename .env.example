VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Chatbot (DeepInfra — OpenAI-compatible Chat Completions API)
# Powers the "Ani" course assistant via /api/chat. Create a token at
# https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
# Optional — override the model. Default: deepseek-ai/DeepSeek-V4-Flash
# (cheapest DeepSeek chat model: $0.09/$0.18 per 1M tokens, 1M context).
# Pricier alternatives: deepseek-ai/DeepSeek-V4-Pro, deepseek-ai/DeepSeek-V3.1
DEEPINFRA_MODEL=
# Optional — override the API base URL (defaults to DeepInfra's OpenAI endpoint)
DEEPINFRA_BASE_URL=

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudflare Proxy for Supabase (optional - use if Supabase is blocked in your region)
# Deploy the cloudflare-worker/supabase-proxy.js to Cloudflare Workers
# Then set this to your Worker URL (e.g., https://supabase-proxy.your-account.workers.dev)
VITE_SUPABASE_PROXY_URL=

# Business Details (for GST Invoices)
BUSINESS_NAME=The Organic Buzz
BUSINESS_GSTIN=23DSDPG2452N1ZR
BUSINESS_ADDRESS=Plot No. 43, Shri Achleshwer Vihar Colony, Near Kanti Nagar, Tansen Road, Gwalior, Madhya Pradesh, India - 474002
BUSINESS_STATE=Madhya Pradesh
BUSINESS_STATE_CODE=23

# Reddit Conversions API (server-side companion to the Reddit Pixel)
# Generate at: ads.reddit.com -> Events Manager -> Conversions API -> Generate access token
REDDIT_CONVERSION_TOKEN=your_reddit_conversion_access_token_here
REDDIT_PIXEL_ID=a2_ixmbsful2p9m
# Optional. When set, CAPI events route to Reddit's test bucket (no real attribution).
# Get from: ads.reddit.com -> Events Manager -> Finish and test -> Send test events
# UNSET this in Production once verified.
REDDIT_CAPI_TEST_ID=
